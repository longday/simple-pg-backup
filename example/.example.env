POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Optional SSH tunnel (leave SSH_HOST unset to connect to Postgres directly).
# With a tunnel, POSTGRES_HOST/POSTGRES_PORT are the database as seen from the SSH host.
#SSH_HOST=host.docker.internal
#SSH_PORT=22
#SSH_USER=youruser
#SSH_KEY_FILE=/run/secrets/ssh_key
#SSH_KEY_PATH=/home/youruser/.ssh/id_ed25519
#SSH_STRICT_HOST_KEY_CHECKING=FALSE
